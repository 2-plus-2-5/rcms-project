# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Data source: 'mock' uses seed data (default), 'sheets' connects to Google Sheets
VITE_DATA_SOURCE=mock

# Google Apps Script web app URL (only needed if VITE_DATA_SOURCE=sheets)
# Get this URL after deploying your Code.gs as a Web App
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# API token (must match the API_TOKEN Script Property in Apps Script)
VITE_API_TOKEN=your-secret-token-here
